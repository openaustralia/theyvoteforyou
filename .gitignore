# See http://help.github.com/ignore-files/ for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# IDEs and vim
/.vscode
/.aider*
/.idea
*~
*.swp
*.swo

# Ignore patch files
*.patch
*.rej

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore all logfiles and tempfiles.
/log/*.log
/log/*.log.0
/tmp
*.bak

config/database.yml
config/settings.yml
config/settings.local.yml
config/settings/*.local.yml

.bundle
.vagrant

# Ignore Byebug command history file.
.byebug_history

# Used by direnv and dotenv
.envrc
.env
.env.local
.env.*.local

# test coverage reports
/coverage

# Ignore the images generated by the rake task application:generate:cards
public/cards

# Ignore output of "export" rake tasks
representatives_distances.csv
representatives_people.csv
senate_distances.csv
senate_people.csv
distances_46th_parliament.csv

# Ignore credential keys
/config/credentials/production.key
/config/credentials/staging.key

# Ignore default dev credentials - production and staging should be seperate 
/config/credentials.yml.enc
/config/master.key

vendor

# Mac Finder
.DS_Store
